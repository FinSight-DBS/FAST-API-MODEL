APP_ENV=production
PORT=8000

# Database (PostgreSQL — same DB as NestJS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finsight_db
DB_USER=finsight_user
DB_PASSWORD=<password_rahasia>

# Model Paths
AUTOENCODER_MODEL_PATH=/app/model/autoencoder/autoencoder.keras
KMEANS_MODEL_PATH=/app/model/clustering/kmeans_all_umap.pkl
KMEANS_LABEL_MAP_PATH=/app/model/clustering/label_map.json
NLP_MODEL_PATH=/app/model/nlp/nlp_model.pkl
NLP_TOKENIZER_PATH=/app/model/nlp/tfidf_vectorizer.pkl

# Anomaly Detection Config
ANOMALY_THRESHOLD_DEFAULT=0.05
ANOMALY_MIN_TRANSACTION_COUNT=15
ANOMALY_LOOKBACK_DAYS=90

# LLM (OpenRouter — https://openrouter.ai/keys)
LLM_API_URL=https://openrouter.ai/api/v1
LLM_API_KEY=<your-openrouter-key>
LLM_MODEL=minimax/minimax-m2.5:free

# Scheduler Security
INTERNAL_API_KEY=<secret_internal_key>

# Cold Start
COLD_START_THRESHOLD_DAYS=30
