APP_ENV=development
PORT=8000

# PostgreSQL (same DB as NestJS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finsight_db
DB_USER=postgres
DB_PASSWORD=postgres

# Model Paths (relative to project root)
AUTOENCODER_MODEL_PATH=models/autoencoder.keras
KMEANS_MODEL_PATH=models/kmeans.joblib
KMEANS_LABEL_MAP_PATH=models/kmeans_label_map.json
NLP_MODEL_PATH=models/indobert_classifier
NLP_TOKENIZER_PATH=models/indobert_classifier

# Anomaly Threshold Config
ANOMALY_THRESHOLD_DEFAULT=0.05
ANOMALY_MIN_TRANSACTION_COUNT=15
ANOMALY_LOOKBACK_DAYS=90

# RAG & LLM
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4o-mini

# Cold Start Config
COLD_START_THRESHOLD_DAYS=30
